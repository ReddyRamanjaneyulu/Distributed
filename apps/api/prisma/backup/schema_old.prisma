generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String

  firstName    String?
  lastName     String?

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  memberships  Membership[]
  sessions     Session[]
  apiKeys      APIKey[]
  auditLogs    AuditLog[]

  @@index([email])
  @@map("users")
}

//////////////////////////////////////////////////////////
// ORGANIZATIONS
//////////////////////////////////////////////////////////

model Organization {
  id          String @id @default(uuid())

  name        String @unique
  slug        String @unique

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String

  projects    Project[]
  members     Membership[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

//////////////////////////////////////////////////////////
// MEMBERSHIPS
//////////////////////////////////////////////////////////

model Membership {
  id String @id @default(uuid())

  userId String
  organizationId String

  role Role @default(VIEWER)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organization Organization
      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])

  @@index([organizationId])

  @@map("memberships")
}

//////////////////////////////////////////////////////////
// PROJECTS
//////////////////////////////////////////////////////////

model Project {

  id String @id @default(uuid())

  organizationId String

  name String

  description String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  organization Organization
      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  queues Queue[]

  @@unique([organizationId, name])

  @@index([organizationId])

  @@map("projects")
}

//////////////////////////////////////////////////////////
// RETRY POLICIES
//////////////////////////////////////////////////////////

model RetryPolicy {

  id String @id @default(uuid())

  name String

  strategy RetryStrategy

  maxRetries Int @default(3)

  fixedDelaySeconds Int?

  linearStepSeconds Int?

  exponentialBase Float?

  exponentialMultiplier Float?

  jitter Boolean @default(false)

  queues Queue[]

  jobs Job[]

  @@map("retry_policies")
}

//////////////////////////////////////////////////////////
// QUEUES
//////////////////////////////////////////////////////////

model Queue {

  id String @id @default(uuid())

  projectId String

  retryPolicyId String?

  name String

  description String?

  priority Int @default(0)

  concurrency Int @default(10)

  visibilityTimeout Int @default(60)

  maxRetries Int @default(3)

  paused Boolean @default(false)

  deadLetterQueueId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  project Project
      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  retryPolicy RetryPolicy?
      @relation(fields: [retryPolicyId], references: [id])

  deadLetterQueue Queue?
      @relation("DeadLetterQueue", fields: [deadLetterQueueId], references: [id])

  sourceQueues Queue[]
      @relation("DeadLetterQueue")

  jobs Job[]

  @@unique([projectId, name])

  @@index([projectId])

  @@index([paused])

  @@index([priority])

  @@map("queues")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum Role {
  OWNER
  ADMIN
  DEVELOPER
  OPERATOR
  VIEWER
}

enum RetryStrategy {
  FIXED_DELAY
  LINEAR_BACKOFF
  EXPONENTIAL_BACKOFF
}
//////////////////////////////////////////////////////////
// JOBS
//////////////////////////////////////////////////////////

model Job {
  id String @id @default(uuid())

  queueId String
  retryPolicyId String?

  workerId String?

  batchId String?

  name String

  payload Json

  metadata Json?

  priority Int @default(0)

  status JobStatus @default(QUEUED)

  retryCount Int @default(0)

  maxRetries Int @default(3)

  availableAt DateTime @default(now())

  scheduledAt DateTime?

  deadlineAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  queue Queue
      @relation(fields: [queueId], references: [id], onDelete: Cascade)

  retryPolicy RetryPolicy?
      @relation(fields: [retryPolicyId], references: [id])

  worker Worker?
      @relation(fields: [workerId], references: [id])

  batch BatchJob?
      @relation(fields: [batchId], references: [id])

  executions JobExecution[]

  logs JobLog[]

  deadLetter DeadLetterQueueEntry?

  @@index([queueId])

  @@index([status])

  @@index([workerId])

  @@index([availableAt])

  @@index([scheduledAt])

  @@index([priority])

  @@index([queueId, status, availableAt])

  @@map("jobs")
}

//////////////////////////////////////////////////////////
// BATCH JOBS
//////////////////////////////////////////////////////////

model BatchJob {

  id String @id @default(uuid())

  projectId String

  name String

  createdAt DateTime @default(now())

  completedAt DateTime?

  jobs Job[]

  @@index([projectId])

  @@map("batch_jobs")
}

//////////////////////////////////////////////////////////
// SCHEDULED JOBS
//////////////////////////////////////////////////////////

model ScheduledJob {

  id String @id @default(uuid())

  queueId String

  name String

  cronExpression String?

  intervalSeconds Int?

  payload Json

  enabled Boolean @default(true)

  nextRunAt DateTime

  lastRunAt DateTime?

  createdAt DateTime @default(now())

  queue Queue
      @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])

  @@index([nextRunAt])

  @@index([enabled])

  @@map("scheduled_jobs")
}

//////////////////////////////////////////////////////////
// JOB EXECUTIONS
//////////////////////////////////////////////////////////

model JobExecution {

  id String @id @default(uuid())

  jobId String

  workerId String?

  attempt Int

  startedAt DateTime @default(now())

  finishedAt DateTime?

  durationMs Int?

  succeeded Boolean @default(false)

  exitCode Int?

  error Json?

  heartbeatAt DateTime?

  job Job
      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  worker Worker?
      @relation(fields: [workerId], references: [id])

  logs JobLog[]

  @@index([jobId])

  @@index([workerId])

  @@index([startedAt])

  @@map("job_executions")
}

//////////////////////////////////////////////////////////
// JOB LOGS
//////////////////////////////////////////////////////////

model JobLog {

  id String @id @default(uuid())

  jobId String

  executionId String?

  level LogLevel @default(INFO)

  message String

  metadata Json?

  createdAt DateTime @default(now())

  job Job
      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  execution JobExecution?
      @relation(fields: [executionId], references: [id])

  @@index([jobId])

  @@index([executionId])

  @@index([createdAt])

  @@map("job_logs")
}

//////////////////////////////////////////////////////////
// DEAD LETTER QUEUE
//////////////////////////////////////////////////////////

model DeadLetterQueueEntry {

  id String @id @default(uuid())

  jobId String @unique

  queueId String

  reason String

  failedAt DateTime @default(now())

  payload Json

  retryCount Int

  movedByWorkerId String?

  job Job
      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  queue Queue
      @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])

  @@index([failedAt])

  @@map("dead_letter_queue")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
  DEAD_LETTER
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}
//////////////////////////////////////////////////////////
// WORKERS
//////////////////////////////////////////////////////////

model Worker {

  id String @id @default(uuid())

  name String

  hostname String?

  ipAddress String?

  version String?

  status WorkerStatus @default(ONLINE)

  maxConcurrency Int @default(10)

  activeJobs Int @default(0)

  totalExecuted Int @default(0)

  totalFailed Int @default(0)

  lastHeartbeat DateTime?

  startedAt DateTime @default(now())

  stoppedAt DateTime?

  metadata Json?

  jobs Job[]

  executions JobExecution[]

  heartbeats WorkerHeartbeat[]

  @@index([status])

  @@index([lastHeartbeat])

  @@map("workers")
}

//////////////////////////////////////////////////////////
// WORKER HEARTBEATS
//////////////////////////////////////////////////////////

model WorkerHeartbeat {

  id String @id @default(uuid())

  workerId String

  timestamp DateTime @default(now())

  cpuUsage Float?

  memoryUsage Float?

  diskUsage Float?

  runningJobs Int?

  queueLatency Int?

  metadata Json?

  worker Worker
      @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])

  @@index([timestamp])

  @@map("worker_heartbeats")
}

//////////////////////////////////////////////////////////
// API KEYS
//////////////////////////////////////////////////////////

model APIKey {

  id String @id @default(uuid())

  userId String

  name String

  keyHash String @unique

  lastUsedAt DateTime?

  expiresAt DateTime?

  createdAt DateTime @default(now())

  revoked Boolean @default(false)

  user User
      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@index([expiresAt])

  @@map("api_keys")
}

//////////////////////////////////////////////////////////
// SESSIONS
//////////////////////////////////////////////////////////

model Session {

  id String @id @default(uuid())

  userId String

  refreshToken String @unique

  expiresAt DateTime

  createdAt DateTime @default(now())

  revokedAt DateTime?

  ipAddress String?

  userAgent String?

  user User
      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@index([expiresAt])

  @@map("sessions")
}

//////////////////////////////////////////////////////////
// AUDIT LOGS
//////////////////////////////////////////////////////////

model AuditLog {

  id String @id @default(uuid())

  userId String?

  organizationId String?

  action String

  resourceType String

  resourceId String?

  ipAddress String?

  userAgent String?

  details Json?

  createdAt DateTime @default(now())

  user User?
      @relation(fields: [userId], references: [id])

  organization Organization?
      @relation(fields: [organizationId], references: [id])

  @@index([userId])

  @@index([organizationId])

  @@index([resourceType])

  @@index([createdAt])

  @@map("audit_logs")
}

//////////////////////////////////////////////////////////
// QUEUE METRICS
//////////////////////////////////////////////////////////

model QueueMetric {

  id String @id @default(uuid())

  queueId String

  pendingJobs Int @default(0)

  runningJobs Int @default(0)

  completedJobs Int @default(0)

  failedJobs Int @default(0)

  retryingJobs Int @default(0)

  deadLetterJobs Int @default(0)

  throughput Float?

  averageLatencyMs Float?

  recordedAt DateTime @default(now())

  queue Queue
      @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])

  @@index([recordedAt])

  @@map("queue_metrics")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum WorkerStatus {
  ONLINE
  OFFLINE
  PAUSED
  DRAINING
}

enum Role {
  OWNER
  ADMIN
  DEVELOPER
  OPERATOR
  VIEWER
}