generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  OWNER
  ADMIN
  DEVELOPER
  OPERATOR
  VIEWER
}

enum QueueStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JobStatus {
  QUEUED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
  DEAD
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  CRON
  BATCH
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum WorkerStatus {
  ONLINE
  OFFLINE
  DRAINING
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  name         String?
  passwordHash String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organizations OrganizationMember[]

  apiKeys  ApiKey[]
  sessions Session[]

  auditLogs AuditLog[]

  @@index([email])
}

//////////////////////////////////////////////////////
// ORGANIZATION
//////////////////////////////////////////////////////

model Organization {
  id String @id @default(uuid())

  name        String  @unique
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members OrganizationMember[]

  projects Project[]

  auditLogs AuditLog[]

  @@index([name])
}

//////////////////////////////////////////////////////
// MEMBERSHIP
//////////////////////////////////////////////////////

model OrganizationMember {
  id String @id @default(uuid())

  userId String

  organizationId String

  role Role @default(VIEWER)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
}

//////////////////////////////////////////////////////
// PROJECT
//////////////////////////////////////////////////////

model Project {
  id String @id @default(uuid())

  name String

  description String?

  organizationId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  queues Queue[]

  auditLogs AuditLog[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

//////////////////////////////////////////////////////
// RETRY POLICY
//////////////////////////////////////////////////////

model RetryPolicy {
  id String @id @default(uuid())

  name     String
  strategy RetryStrategy

  maxAttempts Int
  baseDelayMs Int
  maxDelayMs  Int?

  jitter Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  queues Queue[]
}

//////////////////////////////////////////////////////
// DEAD LETTER QUEUE
//////////////////////////////////////////////////////

model DeadLetterQueue {
  id String @id @default(uuid())

  name String @unique

  description String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  queues Queue[]
}

//////////////////////////////////////////////////////
// QUEUE
//////////////////////////////////////////////////////

model Queue {
  id String @id @default(uuid())

  name String

  description String?

  status QueueStatus @default(ACTIVE)

  priority Int @default(0)

  concurrency Int @default(5)

  visibilityTimeout Int @default(60)

  paused Boolean @default(false)

  projectId String

  retryPolicyId String?

  deadLetterQueueId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id])

  retryPolicy RetryPolicy? @relation(fields: [retryPolicyId], references: [id])

  deadLetterQueue DeadLetterQueue? @relation(fields: [deadLetterQueueId], references: [id])

  jobs Job[]

  scheduledJobs ScheduledJob[]

  workerAssignments WorkerQueueAssignment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([status])
  @@index([priority])
}

//////////////////////////////////////////////////////
// SCHEDULED JOB
//////////////////////////////////////////////////////

model ScheduledJob {
  id String @id @default(uuid())

  name String

  cronExpression String

  timezone String @default("UTC")

  enabled Boolean @default(true)

  payload Json

  nextRunAt DateTime?

  lastRunAt DateTime?

  queueId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  queue Queue @relation(fields: [queueId], references: [id])

  @@index([queueId])
  @@index([enabled])
  @@index([nextRunAt])
}

//////////////////////////////////////////////////////
// BATCH
//////////////////////////////////////////////////////

model Batch {
  id String @id @default(uuid())

  name String

  description String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  jobs Job[]
}

//////////////////////////////////////////////////////
// JOB
//////////////////////////////////////////////////////

model Job {
  id String @id @default(uuid())

  type JobType

  status JobStatus @default(QUEUED)

  payload Json

  priority Int @default(0)

  retryStrategy RetryStrategy

  maxAttempts Int

  baseDelayMs Int

  attempts Int @default(0)

  scheduledAt DateTime?

  availableAt DateTime?

  startedAt DateTime?

  completedAt DateTime?

  failedAt DateTime?

  timeoutAt DateTime?

  cancelledAt DateTime?

  queueId String

  workerId String?

  batchId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  queue Queue @relation(fields: [queueId], references: [id])

  worker Worker? @relation(fields: [workerId], references: [id])

  batch Batch? @relation(fields: [batchId], references: [id])

  executions JobExecution[]

  logs JobLog[]

  @@index([queueId])
  @@index([status])
  @@index([workerId])
  @@index([availableAt])
  @@index([scheduledAt])
  @@index([batchId])
}

//////////////////////////////////////////////////////
// JOB EXECUTION
//////////////////////////////////////////////////////

model JobExecution {
  id String @id @default(uuid())

  attempt Int

  status JobStatus

  startedAt DateTime

  finishedAt DateTime?

  durationMs Int?

  exitCode Int?

  errorMessage String?

  stackTrace String?

  workerId String?

  jobId String

  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  worker Worker? @relation(fields: [workerId], references: [id])

  logs JobLog[]

  @@index([jobId])
  @@index([workerId])
}

//////////////////////////////////////////////////////
// JOB LOG
//////////////////////////////////////////////////////

model JobLog {
  id String @id @default(uuid())

  level LogLevel

  message String

  metadata Json?

  createdAt DateTime @default(now())

  jobId String

  executionId String?

  job Job @relation(fields: [jobId], references: [id])

  execution JobExecution? @relation(fields: [executionId], references: [id])

  @@index([jobId])
  @@index([executionId])
  @@index([level])
}

//////////////////////////////////////////////////////
// WORKER
//////////////////////////////////////////////////////

model Worker {
  id String @id @default(uuid())

  name String

  hostname String

  processId Int

  status WorkerStatus @default(ONLINE)

  version String?

  tags Json?

  startedAt DateTime @default(now())

  lastSeenAt DateTime?

  stoppedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  jobs Job[]

  executions JobExecution[]

  heartbeats WorkerHeartbeat[]

  assignments WorkerQueueAssignment[]

  @@unique([hostname, processId])
  @@index([status])
  @@index([lastSeenAt])
}

//////////////////////////////////////////////////////
// WORKER HEARTBEAT
//////////////////////////////////////////////////////

model WorkerHeartbeat {
  id String @id @default(uuid())

  workerId String

  cpuUsage Float?

  memoryUsage Float?

  activeJobs Int @default(0)

  queuedJobs Int @default(0)

  timestamp DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([timestamp])
}

//////////////////////////////////////////////////////
// WORKER QUEUE ASSIGNMENT
//////////////////////////////////////////////////////

model WorkerQueueAssignment {
  id String @id @default(uuid())

  workerId String

  queueId String

  createdAt DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id])

  queue Queue @relation(fields: [queueId], references: [id])

  @@unique([workerId, queueId])
  @@index([workerId])
  @@index([queueId])
}

//////////////////////////////////////////////////////
// API KEY
//////////////////////////////////////////////////////

model ApiKey {
  id String @id @default(uuid())

  name String

  keyHash String @unique

  enabled Boolean @default(true)

  expiresAt DateTime?

  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([enabled])
}

//////////////////////////////////////////////////////
// SESSION
//////////////////////////////////////////////////////

model Session {
  id String @id @default(uuid())

  refreshTokenHash String

  ipAddress String?

  userAgent String?

  expiresAt DateTime

  revokedAt DateTime?

  createdAt DateTime @default(now())

  userId String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  action String

  entity String

  entityId String?

  description String?

  metadata Json?

  ipAddress String?

  userAgent String?

  createdAt DateTime @default(now())

  userId String?

  organizationId String?

  projectId String?

  user User? @relation(fields: [userId], references: [id])

  organization Organization? @relation(fields: [organizationId], references: [id])

  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([projectId])
  @@index([entity])
}
