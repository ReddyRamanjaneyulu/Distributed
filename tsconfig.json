{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@djs/shared": ["packages/shared/src/index.ts"],
      "@djs/types": ["packages/types/src/index.ts"],
      "@djs/config": ["packages/config/src/index.ts"],
      "@djs/ui": ["packages/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}